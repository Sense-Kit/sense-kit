{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sensekit.dev/schemas/sensekit-signal-batch.v1.schema.json",
  "type": "object",
  "required": [
    "schema_version",
    "batch_id",
    "sent_at",
    "device",
    "signals",
    "delivery"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "const": "sensekit.signal_batch.v1"
    },
    "batch_id": {
      "type": "string",
      "minLength": 1
    },
    "sent_at": {
      "type": "string",
      "format": "date-time"
    },
    "device": {
      "type": "object",
      "required": ["device_id", "platform", "place_sharing_mode"],
      "additionalProperties": false,
      "properties": {
        "device_id": {
          "type": "string",
          "minLength": 1
        },
        "platform": {
          "type": "string",
          "minLength": 1
        },
        "place_sharing_mode": {
          "type": "string",
          "enum": ["labels_only", "precise_coordinates"]
        }
      }
    },
    "signals": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "context-signal.v1.schema.json"
      }
    },
    "delivery": {
      "type": "object",
      "required": ["attempt", "queued_at"],
      "additionalProperties": false,
      "properties": {
        "attempt": {
          "type": "integer",
          "minimum": 1
        },
        "queued_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    }
  }
}
