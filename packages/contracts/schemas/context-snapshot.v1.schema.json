{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sensekit.dev/schemas/context-snapshot.v1.schema.json",
  "type": "object",
  "required": [
    "schema_version",
    "captured_at",
    "routine",
    "place",
    "calendar",
    "device",
    "health"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "const": "sensekit.context_snapshot.v1"
    },
    "captured_at": {
      "type": "string",
      "format": "date-time"
    },
    "routine": {
      "type": "object",
      "required": ["awake", "focus", "workout"],
      "additionalProperties": false,
      "properties": {
        "awake": {
          "type": "boolean"
        },
        "focus": {
          "type": ["string", "null"]
        },
        "workout": {
          "type": "string",
          "enum": ["inactive", "active"]
        }
      }
    },
    "place": {
      "type": "object",
      "required": ["type", "freshness"],
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "enum": ["home", "work", "custom", "other"]
        },
        "identifier": {
          "type": ["string", "null"]
        },
        "name": {
          "type": ["string", "null"]
        },
        "freshness": {
          "type": "string",
          "enum": ["live", "recent", "stale"]
        },
        "coordinate": {
          "type": ["object", "null"],
          "required": ["latitude", "longitude"],
          "additionalProperties": false,
          "properties": {
            "latitude": {
              "type": "number"
            },
            "longitude": {
              "type": "number"
            }
          }
        }
      }
    },
    "calendar": {
      "type": "object",
      "required": ["in_meeting", "next_meeting_in_min", "freshness"],
      "additionalProperties": false,
      "properties": {
        "in_meeting": {
          "type": "boolean"
        },
        "next_meeting_in_min": {
          "type": ["integer", "null"],
          "minimum": 0
        },
        "freshness": {
          "type": "string",
          "enum": ["live", "recent", "stale"]
        }
      }
    },
    "device": {
      "type": "object",
      "required": ["battery_percent_bucket", "charging"],
      "additionalProperties": false,
      "properties": {
        "battery_percent_bucket": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        },
        "charging": {
          "type": "boolean"
        }
      }
    },
    "health": {
      "type": "object",
      "required": ["captured_at", "sleep", "workout", "nutrition", "activity", "recovery", "mind"],
      "additionalProperties": false,
      "properties": {
        "captured_at": {
          "type": "string",
          "format": "date-time"
        },
        "sleep": {
          "$ref": "#/$defs/healthSleep"
        },
        "workout": {
          "$ref": "#/$defs/healthWorkout"
        },
        "nutrition": {
          "$ref": "#/$defs/healthNutrition"
        },
        "activity": {
          "$ref": "#/$defs/healthActivity"
        },
        "recovery": {
          "$ref": "#/$defs/healthRecovery"
        },
        "mind": {
          "$ref": "#/$defs/healthMind"
        }
      }
    }
  },
  "$defs": {
    "freshness": {
      "type": "string",
      "enum": ["live", "recent", "stale"]
    },
    "healthSleep": {
      "type": "object",
      "required": ["available", "authorized", "freshness", "last_sleep_start_at", "last_sleep_end_at", "asleep_minutes", "in_bed_minutes", "seven_day_avg_asleep_minutes", "delta_vs_seven_day_avg_minutes"],
      "additionalProperties": false,
      "properties": {
        "available": { "type": "boolean" },
        "authorized": { "type": "boolean" },
        "freshness": { "$ref": "#/$defs/freshness" },
        "last_sleep_start_at": { "type": ["string", "null"], "format": "date-time" },
        "last_sleep_end_at": { "type": ["string", "null"], "format": "date-time" },
        "asleep_minutes": { "type": ["integer", "null"], "minimum": 0 },
        "in_bed_minutes": { "type": ["integer", "null"], "minimum": 0 },
        "seven_day_avg_asleep_minutes": { "type": ["integer", "null"], "minimum": 0 },
        "delta_vs_seven_day_avg_minutes": { "type": ["integer", "null"] }
      }
    },
    "healthWorkout": {
      "type": "object",
      "required": ["available", "authorized", "freshness", "active", "today_count", "today_total_minutes", "today_active_energy_kcal", "last_type", "last_start_at", "last_end_at"],
      "additionalProperties": false,
      "properties": {
        "available": { "type": "boolean" },
        "authorized": { "type": "boolean" },
        "freshness": { "$ref": "#/$defs/freshness" },
        "active": { "type": "boolean" },
        "today_count": { "type": ["integer", "null"], "minimum": 0 },
        "today_total_minutes": { "type": ["integer", "null"], "minimum": 0 },
        "today_active_energy_kcal": { "type": ["integer", "null"], "minimum": 0 },
        "last_type": { "type": ["string", "null"] },
        "last_start_at": { "type": ["string", "null"], "format": "date-time" },
        "last_end_at": { "type": ["string", "null"], "format": "date-time" }
      }
    },
    "healthNutrition": {
      "type": "object",
      "required": ["available", "authorized", "freshness", "last_logged_at", "protein_g", "protein_target_g", "protein_remaining_g", "calories_kcal", "calories_target_kcal", "calories_remaining_kcal", "water_ml", "water_target_ml", "water_remaining_ml"],
      "additionalProperties": false,
      "properties": {
        "available": { "type": "boolean" },
        "authorized": { "type": "boolean" },
        "freshness": { "$ref": "#/$defs/freshness" },
        "last_logged_at": { "type": ["string", "null"], "format": "date-time" },
        "protein_g": { "type": ["integer", "null"], "minimum": 0 },
        "protein_target_g": { "type": ["integer", "null"], "minimum": 0 },
        "protein_remaining_g": { "type": ["integer", "null"] },
        "calories_kcal": { "type": ["integer", "null"], "minimum": 0 },
        "calories_target_kcal": { "type": ["integer", "null"], "minimum": 0 },
        "calories_remaining_kcal": { "type": ["integer", "null"] },
        "water_ml": { "type": ["integer", "null"], "minimum": 0 },
        "water_target_ml": { "type": ["integer", "null"], "minimum": 0 },
        "water_remaining_ml": { "type": ["integer", "null"] }
      }
    },
    "healthActivity": {
      "type": "object",
      "required": ["available", "authorized", "freshness", "steps", "active_energy_kcal", "distance_km", "seven_day_avg_steps_by_now", "delta_vs_seven_day_avg_steps_by_now"],
      "additionalProperties": false,
      "properties": {
        "available": { "type": "boolean" },
        "authorized": { "type": "boolean" },
        "freshness": { "$ref": "#/$defs/freshness" },
        "steps": { "type": ["integer", "null"], "minimum": 0 },
        "active_energy_kcal": { "type": ["integer", "null"], "minimum": 0 },
        "distance_km": { "type": ["number", "null"], "minimum": 0 },
        "seven_day_avg_steps_by_now": { "type": ["integer", "null"], "minimum": 0 },
        "delta_vs_seven_day_avg_steps_by_now": { "type": ["integer", "null"] }
      }
    },
    "healthRecovery": {
      "type": "object",
      "required": ["available", "authorized", "freshness", "resting_heart_rate_bpm", "resting_heart_rate_delta_vs_14_day_avg_bpm", "hrv_sdnn_ms", "hrv_delta_vs_14_day_avg_ms", "measured_at"],
      "additionalProperties": false,
      "properties": {
        "available": { "type": "boolean" },
        "authorized": { "type": "boolean" },
        "freshness": { "$ref": "#/$defs/freshness" },
        "resting_heart_rate_bpm": { "type": ["integer", "null"], "minimum": 0 },
        "resting_heart_rate_delta_vs_14_day_avg_bpm": { "type": ["integer", "null"] },
        "hrv_sdnn_ms": { "type": ["integer", "null"], "minimum": 0 },
        "hrv_delta_vs_14_day_avg_ms": { "type": ["integer", "null"] },
        "measured_at": { "type": ["string", "null"], "format": "date-time" }
      }
    },
    "healthMind": {
      "type": "object",
      "required": ["available", "authorized", "freshness", "latest_state", "logged_at"],
      "additionalProperties": false,
      "properties": {
        "available": { "type": "boolean" },
        "authorized": { "type": "boolean" },
        "freshness": { "$ref": "#/$defs/freshness" },
        "latest_state": { "type": ["string", "null"] },
        "logged_at": { "type": ["string", "null"], "format": "date-time" }
      }
    }
  }
}
